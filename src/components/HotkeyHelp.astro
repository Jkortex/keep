---
import Icon from './Icon.astro';

interface Props {
  shortcuts: { keys: string; desc: string }[];
}

const { shortcuts } = Astro.props as Props;
---

<div
  id="hotkey-help-overlay"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/40 backdrop-blur-sm"
>
  <div
    class="mx-4 w-full max-w-md rounded-2xl border border-border bg-background p-6 shadow-2xl dark:border-border dark:bg-muted"
  >
    <div class="mb-5 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-foreground">快捷键</h2>
      <button
        id="hotkey-help-close"
        class="inline-flex min-h-[44px] min-w-[44px] sm:h-7 sm:w-7 items-center justify-center rounded-lg text-dim transition-colors duration-200 hover:bg-muted hover:text-foreground dark:hover:bg-border dark:hover:text-foreground"
        aria-label="关闭"
      >
        <Icon name="x" size={16} />
      </button>
    </div>
    <div class="space-y-1">
      {shortcuts.map(({ keys, desc }) => (
        <div class="flex items-center justify-between rounded-lg px-3 py-2 transition-colors duration-200 hover:bg-muted dark:hover:bg-border">
          <span class="text-sm text-secondary dark:text-[#D1D5DB]">{desc}</span>
          <kbd class="inline-flex items-center gap-0.5 rounded-md border border-border bg-white px-2 py-0.5 font-mono text-xs font-medium text-subtle dark:border-secondary dark:bg-background dark:text-dim">
            {keys}
          </kbd>
        </div>
      ))}
    </div>
  </div>
</div>

---
export interface Props {
  href: string;
  title: string;
  description: string;
  count: number;
}

const { href, title, description, count } = Astro.props as Props;
---

<a
  href={href}
  class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md no-underline dark:border-slate-700 dark:bg-slate-800/50 dark:hover:bg-slate-800"
>
  <div
    class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-slate-700 dark:text-blue-400"
  >
    <slot name="icon" />
  </div>
  <h2
    class="text-base font-semibold text-slate-900 transition-colors group-hover:text-blue-600 dark:text-slate-100 dark:group-hover:text-blue-400"
  >
    {title}
  </h2>
  <p class="mt-1.5 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
    {description}
  </p>
  <span
    class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-blue-600 dark:text-blue-400"
  >
    {count} 篇
    <svg
      class="h-3 w-3"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
    >
  </span>
</a>

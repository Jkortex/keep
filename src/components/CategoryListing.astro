---
import ArticleCard from './ArticleCard.astro';
import Icon from './Icon.astro';
import * as k from '../lib/knowledge';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  category: string;
  articles: CollectionEntry<'knowledge'>[];
  currentPage: number;
  totalPages: number;
}

const { category, articles, currentPage, totalPages } = Astro.props;
const title = k.getCategoryLabel(category);

function pageUrl(cat: string, page: number): string {
  return page === 1 ? `/knowledge/${cat}` : `/knowledge/${cat}/${page}`;
}
---

<section class="not-prose">
  <div class="mb-6 flex items-center gap-3">
    <div
      class="flex h-9 w-9 items-center justify-center rounded-lg bg-[#ECFDF5] text-[#059669] dark:bg-[rgba(5,150,105,0.1)] dark:text-[#34D399]"
    >
      <Icon name="folder" size={20} />
    </div>
    <h1 class="text-[24px] font-semibold tracking-tight text-[#1A1A1A] dark:text-[#F3F4F6]">
      {title}
    </h1>
  </div>

  <div class="space-y-0.5">
    {articles.map((article) => <ArticleCard entry={article} />)}
  </div>

  {articles.length === 0 && <p class="text-[15px] text-[#9CA3AF] dark:text-[#6B7280]">此分类暂无内容</p>}

  {totalPages > 1 && (
    <nav class="mt-10 flex items-center justify-center gap-1.5 sm:gap-1">
      {currentPage > 1 ? (
        <a
          href={pageUrl(category, currentPage - 1)}
          class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 items-center justify-center rounded-lg border border-[#E5E7EB] text-[#6B7280] transition-colors duration-200 hover:border-[#059669] hover:text-[#059669] dark:border-[#374151] dark:text-[#9CA3AF] dark:hover:border-[#34D399] dark:hover:text-[#34D399]"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
      ) : (
        <span class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 cursor-not-allowed items-center justify-center rounded-lg border border-[#E5E7EB] text-[#D1D5DB] dark:border-[#374151] dark:text-[#4B5563]">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </span>
      )}

      {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
        <a
          href={pageUrl(category, p)}
          class:list={[
            'flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 items-center justify-center rounded-lg text-[13px] font-medium transition-colors duration-200 no-underline',
            p === currentPage
              ? 'bg-[#059669] text-white'
              : 'border border-[#E5E7EB] text-[#6B7280] hover:border-[#059669] hover:text-[#059669] dark:border-[#374151] dark:text-[#9CA3AF] dark:hover:border-[#34D399] dark:hover:text-[#34D399]',
          ]}
          aria-current={p === currentPage ? 'page' : undefined}
        >
          {p}
        </a>
      ))}

      {currentPage < totalPages ? (
        <a
          href={pageUrl(category, currentPage + 1)}
          class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 items-center justify-center rounded-lg border border-[#E5E7EB] text-[#6B7280] transition-colors duration-200 hover:border-[#059669] hover:text-[#059669] dark:border-[#374151] dark:text-[#9CA3AF] dark:hover:border-[#34D399] dark:hover:text-[#34D399]"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      ) : (
        <span class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 cursor-not-allowed items-center justify-center rounded-lg border border-[#E5E7EB] text-[#D1D5DB] dark:border-[#374151] dark:text-[#4B5563]">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      )}
    </nav>
  )}
</section>

---
import ArticleCard from './ArticleCard.astro';
import Icon from './Icon.astro';
import * as k from '../lib/knowledge';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  category: string;
  articles: CollectionEntry<'knowledge'>[];
  currentPage: number;
  totalPages: number;
}

const { category, articles, currentPage, totalPages } = Astro.props;
const title = k.getCategoryLabel(category);

function pageUrl(cat: string, page: number): string {
  return page === 1 ? `/knowledge/${cat}` : `/knowledge/${cat}/${page}`;
}
---

<section class="not-prose">
  <div class="mb-6 flex items-center gap-3">
    <div
      class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent-light text-accent dark:bg-accent/10 dark:text-brand-400"
    >
      <Icon name="chart-column-stacked" size={20} />
    </div>
    <h1 class="text-2xl font-semibold tracking-tight text-foreground">
      {title}
    </h1>
  </div>

  <div class="space-y-0.5">
    {articles.map((article) => <ArticleCard entry={article} />)}
  </div>

  {articles.length === 0 && <p class="text-[15px] text-dim">此分类暂无内容</p>}

  {totalPages > 1 && (
    <nav class="mt-10 flex items-center justify-center gap-1.5 sm:gap-1">
      {currentPage > 1 ? (
        <a
          href={pageUrl(category, currentPage - 1)}
          class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 items-center justify-center rounded-lg border border-border text-subtle transition-colors duration-200 hover:border-accent hover:text-accent dark:hover:border-brand-400 dark:hover:text-brand-400"
        >
          <Icon name="chevron-left" size={16} />
        </a>
      ) : (
        <span class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 cursor-not-allowed items-center justify-center rounded-lg border border-border text-[#D1D5DB] dark:border-border dark:text-secondary">
          <Icon name="chevron-left" size={16} />
        </span>
      )}

      {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
        <a
          href={pageUrl(category, p)}
          class:list={[
            'flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 items-center justify-center rounded-lg text-xs font-medium transition-colors duration-200 no-underline',
            p === currentPage
              ? 'bg-accent text-white'
              : 'border border-border text-subtle hover:border-accent hover:text-accent dark:hover:border-brand-400 dark:hover:text-brand-400',
          ]}
          aria-current={p === currentPage ? 'page' : undefined}
        >
          {p}
        </a>
      ))}

      {currentPage < totalPages ? (
        <a
          href={pageUrl(category, currentPage + 1)}
          class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 items-center justify-center rounded-lg border border-border text-subtle transition-colors duration-200 hover:border-accent hover:text-accent dark:hover:border-brand-400 dark:hover:text-brand-400"
        >
          <Icon name="chevron-right" size={16} />
        </a>
      ) : (
        <span class="flex min-h-[44px] min-w-[44px] sm:h-8 sm:w-8 cursor-not-allowed items-center justify-center rounded-lg border border-border text-[#D1D5DB] dark:border-border dark:text-secondary">
          <Icon name="chevron-right" size={16} />
        </span>
      )}
    </nav>
  )}
</section>

---
import { codeToHtml } from 'shiki';
import type { CodeDemoProps, SourceFile } from '../types';

const { code, lang = 'html', files } = Astro.props as CodeDemoProps;

const sources: SourceFile[] = files ?? [{ name: `demo.${lang}`, code: code ?? '' }];

// Highlight each source file
const highlighted = await Promise.all(
  sources.map(async (f) => ({
    ...f,
    html: await codeToHtml(f.code, { lang: f.name.endsWith('.css') ? 'css' : lang, theme: 'github-dark' }).catch(
      () => `<pre class="m-0 overflow-x-auto bg-slate-900 p-4 text-sm leading-relaxed text-slate-100 dark:bg-slate-950"><code>${f.code}</code></pre>`
    ),
  }))
);
---

<div class="not-prose my-6 overflow-hidden rounded-xl border shadow-sm border-slate-200 bg-white dark:border-slate-700 dark:bg-slate-800/50">
  <!-- Preview -->
  <section>
    <div class="flex items-center justify-between border-b px-4 py-2 border-slate-100 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/80">
      <span class="flex items-center gap-1.5 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 12h20" /><path d="M12 2v20" />
        </svg>
        Preview
      </span>
    </div>
    <div class="flex min-h-[120px] items-center justify-center p-6">
      <slot />
    </div>
  </section>

  <!-- Code -->
  <section class="border-t border-slate-200 dark:border-slate-700">
    <div class="flex items-center gap-2 border-b px-4 py-2 border-slate-100 bg-slate-50 dark:border-slate-700 dark:bg-slate-800/80">
      <span class="flex items-center gap-1.5 text-[0.7rem] font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4" />
          <path d="M14 2v4a2 2 0 0 0 2 2h4" />
          <path d="m5 12-3 3 3 3" />
          <path d="m9 18 3-3-3-3" />
        </svg>
        Source
      </span>
      <span class="rounded px-1.5 py-0.5 font-mono text-[0.65rem] bg-slate-200 text-slate-500 dark:bg-slate-600 dark:text-slate-300">{lang}</span>
    </div>
    <div class="max-h-96 overflow-auto">
      {
        highlighted.map((file) => (
          <details open>
            {highlighted.length > 1 && (
              <summary class="cursor-pointer border-b px-4 py-1.5 font-mono text-xs select-none transition-colors border-slate-100 bg-slate-50/50 text-slate-500 hover:bg-slate-100/50 dark:border-slate-700 dark:bg-slate-800/30 dark:text-slate-400 dark:hover:bg-slate-700/50">
                {file.name}
              </summary>
            )}
            <Fragment set:html={file.html} />
          </details>
        ))
      }
    </div>
  </section>
</div>

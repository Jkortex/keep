---
/**
 * CodeDemo — 并排展示渲染效果与源码。
 *
 * Props:
 *   code: string   — 源码文本
 *   lang: string   — 代码语言 (default 'html')
 *   files?: { name: string; code: string }[]
 */

interface FileTab {
  name: string;
  code: string;
}

const { code, lang = 'html', files } = Astro.props as {
  code?: string;
  lang?: string;
  files?: FileTab[];
};

const sources = files ?? [{ name: `demo.${lang}`, code: code ?? '' }];
---

<div class="my-6 overflow-hidden rounded-xl border border-stone-200 bg-white shadow-sm">
  <!-- Preview -->
  <section>
    <div class="flex items-center justify-between border-b border-stone-100 bg-stone-50 px-4 py-2">
      <span class="text-[0.7rem] font-semibold uppercase tracking-widest text-stone-400">Preview</span>
    </div>
    <div class="flex min-h-[120px] items-center justify-center p-6">
      <slot />
    </div>
  </section>

  <!-- Code -->
  <section class="border-t border-stone-200">
    <div class="flex items-center gap-2 border-b border-stone-100 bg-stone-50 px-4 py-2">
      <span class="text-[0.7rem] font-semibold uppercase tracking-widest text-stone-400">Source</span>
      <span class="rounded bg-stone-200 px-1.5 py-0.5 text-[0.65rem] font-mono text-stone-500">{lang}</span>
    </div>
    <div class="max-h-96 overflow-auto">
      {
        sources.map((file) => (
          <details open>
            {sources.length > 1 && (
              <summary class="cursor-pointer border-b border-stone-100 bg-stone-50/50 px-4 py-1.5 text-xs font-mono text-stone-500 select-none hover:bg-stone-100/50">
                {file.name}
              </summary>
            )}
            <pre class="m-0 overflow-x-auto bg-stone-900 p-4 text-sm leading-relaxed text-stone-100"><code>{file.code}</code></pre>
          </details>
        ))
      }
    </div>
  </section>
</div>

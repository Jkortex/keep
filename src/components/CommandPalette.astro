---
import Icon from './Icon.astro';
---

<div
  id="command-palette-overlay"
  style="display: none"
  class="fixed inset-0 z-[150] hidden items-start justify-center pt-[12vh] bg-black/30 backdrop-blur-sm"
>
  <div
    class="mx-4 w-full max-w-2xl rounded-2xl border border-border bg-background shadow-2xl dark:border-border dark:bg-muted overflow-hidden"
  >
    <!-- Input -->
    <div class="flex items-center gap-3 border-b border-border px-5 py-3">
      <Icon name="command" size={16} class="shrink-0 text-dim" />
      <input
        id="palette-input"
        type="text"
        placeholder="搜索文章，> 命令，@ 分类，# 页内符号"
        class="w-full border-0 bg-transparent text-[15px] text-foreground outline-none placeholder:text-dim"
        autocomplete="off"
        spellcheck="false"
      />
      <span id="palette-mode-badge" class="hidden rounded-md bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent dark:bg-brand-400/10 dark:text-brand-400"></span>
    </div>

    <!-- Mode shortcuts (mobile-friendly) -->
    <div id="palette-shortcuts" class="hidden gap-2 border-b border-border px-5 py-2.5">
      <button class="palette-mode-btn cursor-pointer rounded-md border border-border px-3 py-1 text-xs font-medium text-subtle transition-colors hover:border-accent hover:text-accent dark:hover:border-brand-400 dark:hover:text-brand-400" data-mode="command">
        &gt; 命令
      </button>
      <button class="palette-mode-btn cursor-pointer rounded-md border border-border px-3 py-1 text-xs font-medium text-subtle transition-colors hover:border-accent hover:text-accent dark:hover:border-brand-400 dark:hover:text-brand-400" data-mode="category">
        @ 分类
      </button>
      <button class="palette-mode-btn cursor-pointer rounded-md border border-border px-3 py-1 text-xs font-medium text-subtle transition-colors hover:border-accent hover:text-accent dark:hover:border-brand-400 dark:hover:text-brand-400" data-mode="symbol">
        # 页内符号
      </button>
    </div>

    <!-- Results -->
    <div id="palette-results" class="scrollbar-thin max-h-[50vh] overflow-y-auto py-2 pr-1">
      <div class="px-5 py-8 text-center text-[13px] text-dim">
        输入搜索文章，<kbd class="mx-0.5 rounded border border-border bg-white px-1.5 py-0.5 font-mono text-xs dark:border-secondary dark:bg-background">&gt;</kbd> 命令，<kbd class="mx-0.5 rounded border border-border bg-white px-1.5 py-0.5 font-mono text-xs dark:border-secondary dark:bg-background">@</kbd> 分类，<kbd class="mx-0.5 rounded border border-border bg-white px-1.5 py-0.5 font-mono text-xs dark:border-secondary dark:bg-background">#</kbd> 页内符号
      </div>
    </div>
  </div>
</div>

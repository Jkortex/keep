---
import {
  Search,
  ChevronRight,
  ChevronLeft,
  ChevronUp,
  ChevronDown,
  Sun,
  Moon,
  File,
  Terminal,
  House,
  Calendar,
  Clock,
  Folder,
  Hash,
  X,
  Menu,
  ArrowUp,
  Copy,
  List,
  Plus,
  ChartColumnStacked,
} from '@lucide/astro';

export interface Props {
  name:
    | 'search'
    | 'chevron-right'
    | 'chevron-left'
    | 'chevron-up'
    | 'chevron-down'
    | 'sun'
    | 'moon'
    | 'file'
    | 'command'
    | 'home'
    | 'calendar'
    | 'clock'
    | 'folder'
    | 'chart-column-stacked'
    | 'x'
    | 'menu'
    | 'arrow-up'
    | 'copy'
    | 'list'
  | 'plus';
  class?: string;
  size?: number;
}

const { name, class: className = '', size = 16 } = Astro.props as Props;

const iconMap: Record<string, any> = {
  search: Search,
  'chevron-right': ChevronRight,
  'chevron-left': ChevronLeft,
  'chevron-up': ChevronUp,
  'chevron-down': ChevronDown,
  sun: Sun,
  moon: Moon,
  file: File,
  command: Terminal,
  home: House,
  calendar: Calendar,
  clock: Clock,
  folder: Folder,
  hashtag: Hash,
  'chart-column-stacked': ChartColumnStacked,
  x: X,
  menu: Menu,
  'arrow-up': ArrowUp,
  copy: Copy,
  list: List,
  plus: Plus,
};

const LucideIcon = iconMap[name];
if (!LucideIcon) return;
---
<LucideIcon class={className} size={size} />

---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'knowledge'>;
  /** 简洁列表行（首页 feed 用，无 card 背景/圆角/内边距） */
  simple?: boolean;
}

const { entry, simple = false } = Astro.props;
const { title, description, tags } = entry.data;
const href = '/knowledge/' + entry.id;
---

<a
  href={href}
  data-category={simple ? entry.id.split('/')[0] : undefined}
  data-tags={tags?.join(',')}
  class:list={[
    'flex items-center gap-3 no-underline transition-colors',
    simple
      ? 'group py-2.5 text-sm text-slate-600 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400'
      : 'rounded-lg px-3 py-2.5 -mx-3 text-slate-600 hover:bg-slate-50 hover:text-blue-600 dark:text-slate-400 dark:hover:bg-slate-800/50 dark:hover:text-blue-400',
  ]}
>
  <svg
    class="h-3.5 w-3.5 shrink-0 text-slate-400 transition-colors group-hover:text-blue-500 dark:text-slate-500"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    ><path d="m9 18 6-6-6-6"></path>
  </svg>

  <div class="min-w-0 flex-1">
    <div class="truncate text-sm font-medium">{title}</div>
    {
      description && (
        <div class="mt-0.5 truncate text-xs text-slate-400 dark:text-slate-500">{description}</div>
      )
    }
  </div>

  {
    tags && tags.length > 0 && (
      <div class="hidden shrink-0 gap-1.5 sm:flex relative z-10">
        {tags.slice(0, 3).map((tag) => (
          <span
            data-tag-click={tag}
            class="rounded-md bg-slate-100 px-1.5 py-0.5 font-mono text-[0.625rem] text-slate-500 hover:bg-blue-50 hover:text-blue-600 dark:bg-slate-800 dark:text-slate-400 dark:hover:bg-blue-950/50 dark:hover:text-blue-400 transition-colors cursor-pointer"
          >
            #{tag}
          </span>
        ))}
      </div>
    )
  }
</a>

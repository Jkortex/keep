---
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';
import * as k from '../lib/knowledge';

export interface Props {
  entry: CollectionEntry<'knowledge'>;
  /** 简洁列表行（首页 feed 用，无 card 背景/圆角/内边距） */
  simple?: boolean;
  date?: string;
  category?: string;
}

const { entry, simple = false, date, category } = Astro.props;
const { title, description, tags } = entry.data;
const href = '/knowledge/' + entry.id;
---

{
  simple ? (
    <a
      href={href}
      data-category={k.getCategorySlug(entry)}
      data-tags={tags?.join(',')}
      class="group block border-b border-muted py-5 no-underline transition-colors duration-200 last:border-b-0 hover:bg-[#F9FAF7] dark:border-muted dark:hover:bg-[#1A221E]"
    >
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2 mb-1.5">
            {category && (
              <span class="text-xs font-medium text-accent dark:text-brand-400">
                {category}
              </span>
            )}
            {date && (
              <span class="text-xs text-dim">
                {date}
              </span>
            )}
          </div>
          <h3 class="text-[15px] font-medium leading-snug text-foreground group-hover:text-accent transition-colors duration-200 dark:group-hover:text-brand-400">
            {title}
          </h3>
          {description && (
            <p class="mt-1 text-sm leading-relaxed text-subtle line-clamp-2">
              {description}
            </p>
          )}
          {tags && tags.length > 0 && (
            <div class="mt-2.5 flex flex-wrap gap-1.5">
              {tags.slice(0, 4).map((tag) => (
                <span
                  data-tag-click={tag}
                  class="inline-block rounded-md bg-muted px-2 py-0.5 text-[11px] font-medium text-subtle hover:bg-accent-light hover:text-accent transition-colors duration-200 cursor-pointer dark:bg-muted dark:hover:bg-accent/10 dark:hover:text-brand-400"
                >
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
        <Icon name="chevron-right" size={16} class="mt-1 shrink-0 text-[#D1D5DB] transition-colors duration-200 group-hover:text-accent dark:text-border dark:group-hover:text-brand-400" />
      </div>
    </a>
  ) : (
    <a
      href={href}
      data-category={k.getCategorySlug(entry)}
      data-tags={tags?.join(',')}
      class="group flex items-start gap-3 rounded-lg px-3 py-3 -mx-3 no-underline text-foreground transition-colors duration-200 hover:bg-[#F0F9F6] dark:text-[#E5E7EB] dark:hover:bg-muted"
    >
      <Icon name="chevron-right" size={16} class="mt-0.5 shrink-0 text-[#D1D5DB] transition-colors duration-200 group-hover:text-accent dark:text-secondary dark:group-hover:text-brand-400" />

      <div class="min-w-0 flex-1">
        <div class="text-[15px] font-medium leading-snug">
          {title}
        </div>
        {description && (
          <div class="mt-1 text-[13px] leading-relaxed text-subtle">
            {description}
          </div>
        )}
      </div>
    </a>
  )
}

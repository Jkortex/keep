---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'knowledge'>;
}

const { entry } = Astro.props;
const { title, description, tags } = entry.data;
const href = '/knowledge/' + entry.id;
---

<a
  href={href}
  class="flex items-center gap-3 rounded-lg px-3 py-2.5 -mx-3 text-slate-600 no-underline transition-colors hover:bg-slate-50 hover:text-blue-600 dark:text-slate-400 dark:hover:bg-slate-800/50 dark:hover:text-blue-400"
>
  <svg
    class="h-4 w-4 shrink-0 text-slate-400 dark:text-slate-500"
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
  >
  <div class="min-w-0">
    <div class="text-sm font-medium truncate">{title}</div>
    {description && (
      <div class="mt-0.5 text-xs text-slate-400 dark:text-slate-500 truncate">
        {description}
      </div>
    )}
  </div>
  {tags && tags.length > 0 && (
    <div class="ml-auto hidden shrink-0 gap-1.5 sm:flex">
      {tags.slice(0, 3).map((tag) => (
        <span class="rounded-md bg-slate-100 px-1.5 py-0.5 font-mono text-[0.65rem] text-slate-500 dark:bg-slate-700 dark:text-slate-400">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>

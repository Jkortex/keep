---
/** 根据当前路径自动生成面包屑导航 */
import { getCollection } from 'astro:content';

export interface Props {
  path: URL;
}

const { path } = Astro.props as Props;
const segments = path.pathname.replace(/\/$/, '').split('/').filter(Boolean);

// Load all articles to build categorySlug → displayName mapping
const articles = await getCollection('knowledge');
const categoryLabels: Record<string, string> = {};
for (const article of articles) {
  const catSlug = article.id.split('/')[0];
  if (!categoryLabels[catSlug]) {
    categoryLabels[catSlug] = article.data.category;
  }
}

// Build article slug → title mapping
const articleLabels: Record<string, string> = {};
for (const article of articles) {
  articleLabels[article.id] = article.data.title;
}

// Fixed labels for top-level paths
const fixedLabels: Record<string, string> = {
  knowledge: '所有知识',
};

function getLabel(seg: string): string {
  return fixedLabels[seg] ?? categoryLabels[seg] ?? decodeURIComponent(seg.replace(/-/g, ' '));
}
---

<nav
  aria-label="面包屑"
  class="not-prose mb-6 flex items-center gap-1.5 text-sm text-slate-400 dark:text-slate-500"
>
  <a
    href="/"
    class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors no-underline text-slate-400 dark:text-slate-500"
  >
    <svg
      class="h-3.5 w-3.5"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
    </svg>
  </a>
  {
    segments.map((seg, i) => {
      const href = '/' + segments.slice(0, i + 1).join('/');
      const label = getLabel(seg);
      const isLast = i === segments.length - 1;
      return (
        <>
          <svg
            class="h-3 w-3 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
          {isLast ? (
            <span class="font-medium text-slate-700 dark:text-slate-300 capitalize">{label}</span>
          ) : (
            <a
              href={href}
              class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors no-underline text-slate-400 dark:text-slate-500 capitalize"
            >
              {label}
            </a>
          )}
        </>
      );
    })
  }
</nav>

---
import Icon from './Icon.astro';
import * as k from '../lib/knowledge';

export interface Props {
  path: URL;
  currentTitle?: string;
}

const { path, currentTitle } = Astro.props as Props;
const segments = path.pathname.replace(/\/$/, '').split('/').filter(Boolean);
if (segments.length === 0) segments.push('home');

const breadcrumbLabels: Record<string, string> = {
  home: '所有知识',
};

function getLabel(seg: string, i: number): string {
  if (i === segments.length - 1 && currentTitle) return currentTitle;
  return breadcrumbLabels[seg] ?? k.getCategoryLabel(seg);
}
---

<nav
  aria-label="面包屑"
  class="not-prose mb-6 flex items-center gap-1.5 text-[13px] text-dim"
>
  <a
    href="/"
    class="no-underline transition-colors duration-200 hover:text-accent dark:hover:text-brand-400 text-dim"
  >
    <Icon name="home" size={14} />
  </a>
  {
    segments.map((seg, i) => {
      if (seg === 'knowledge') return null;
      const href = '/' + segments.slice(0, i + 1).join('/');
      const label = getLabel(seg, i);
      const isLast = i === segments.length - 1;
      return (
        <>
          <Icon name="chevron-right" size={12} class="shrink-0" />
          {isLast ? (
            <span class="font-medium text-foreground capitalize">{label}</span>
          ) : (
            <a
              href={href}
              class="no-underline transition-colors duration-200 hover:text-accent dark:hover:text-brand-400 text-dim capitalize"
            >
              {label}
            </a>
          )}
        </>
      );
    })
  }
</nav>

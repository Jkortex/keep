---
import * as k from '../lib/knowledge';

export interface Props {
  path: URL;
  currentTitle?: string;
}

const { path, currentTitle } = Astro.props as Props;
const segments = path.pathname.replace(/\/$/, '').split('/').filter(Boolean);
if (segments.length === 0) segments.push('home');

const breadcrumbLabels: Record<string, string> = {
  home: '所有知识',
};

function getLabel(seg: string, i: number): string {
  if (i === segments.length - 1 && currentTitle) return currentTitle;
  return breadcrumbLabels[seg] ?? k.getCategoryLabel(seg);
}
---

<nav
  aria-label="面包屑"
  class="not-prose mb-6 flex items-center gap-1.5 text-[13px] text-[#9CA3AF] dark:text-[#6B7280]"
>
  <a
    href="/"
    class="no-underline transition-colors duration-200 hover:text-[#059669] dark:hover:text-[#34D399] text-[#9CA3AF] dark:text-[#6B7280]"
  >
    <svg
      class="h-3.5 w-3.5"
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
    </svg>
  </a>
  {
    segments.map((seg, i) => {
      if (seg === 'knowledge') return null;
      const href = '/' + segments.slice(0, i + 1).join('/');
      const label = getLabel(seg, i);
      const isLast = i === segments.length - 1;
      return (
        <>
          <svg
            class="h-3 w-3 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
          {isLast ? (
            <span class="font-medium text-[#1A1A1A] dark:text-[#F3F4F6] capitalize">{label}</span>
          ) : (
            <a
              href={href}
              class="no-underline transition-colors duration-200 hover:text-[#059669] dark:hover:text-[#34D399] text-[#9CA3AF] dark:text-[#6B7280] capitalize"
            >
              {label}
            </a>
          )}
        </>
      );
    })
  }
</nav>

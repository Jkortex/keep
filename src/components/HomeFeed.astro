---
import ArticleCard from './ArticleCard.astro';
import Icon from './Icon.astro';
import * as k from '../lib/knowledge';

const categories = await k.getCategoriesWithCounts();
const grouped = await k.getArticlesGroupedByCategory();
---

<section class="not-prose">
  <div id="active-filters-container" class="mb-6 flex gap-2"></div>
  <div class="mt-2">
    {categories.map(({ slug, title, count }) => {
      const items = grouped.get(slug) ?? [];
      const preview = items.slice(0, 2);
      return (
        <div class="mb-12">
          <div class="mb-4 flex items-center gap-2">
            <Icon name="chart-column-stacked" size={18} class="text-accent dark:text-brand-400" />
            <a
              href={'/knowledge/' + slug}
              class="text-base font-semibold text-foreground no-underline transition-colors duration-200 hover:text-accent dark:hover:text-brand-400"
            >
              {title}
            </a>
            <span class="text-[13px] text-dim">({count} 篇)</span>
            {count > 2 && (
              <a
                href={'/knowledge/' + slug}
                class="ml-auto inline-flex items-center gap-0.5 text-[13px] font-medium text-accent no-underline transition-colors duration-200 hover:text-accent-hover dark:text-brand-400 dark:hover:text-brand-300"
              >
                查看全部
                <Icon name="chevron-right" size={14} />
              </a>
            )}
          </div>
          <div class="space-y-0.5">
            {preview.map((article) => <ArticleCard entry={article} />)}
          </div>
        </div>
      );
    })}
  </div>

  {categories.length === 0 && <p class="text-[15px] text-dim">暂无内容</p>}
</section>

<script>
  const rows = document.querySelectorAll('[data-category]') as NodeListOf<HTMLElement>;

  function removeActiveTagPill() {
    const activeTagPill = document.getElementById('active-tag-pill');
    if (activeTagPill) activeTagPill.remove();
  }

  function clearTagQueryParam() {
    const url = new URL(window.location.href);
    if (url.searchParams.has('tag')) {
      url.searchParams.delete('tag');
      window.history.replaceState({}, '', url.toString());
    }
  }

  function setTagQueryParam(tag: string) {
    const url = new URL(window.location.href);
    if (url.searchParams.get('tag') !== tag) {
      url.searchParams.set('tag', tag);
      window.history.replaceState({}, '', url.toString());
    }
  }

  // ── Tag filtering via delegation ──
  function filterByTag(tag: string) {
    // Manage dynamic active tag pill
    let activeTagPill = document.getElementById('active-tag-pill') as HTMLButtonElement | null;
    const filterContainer = document.getElementById('active-filters-container');
    
    if (!activeTagPill && filterContainer) {
      activeTagPill = document.createElement('button');
      activeTagPill.id = 'active-tag-pill';
      activeTagPill.className =
        'feed-pill active shrink-0 rounded-full border px-3.5 py-1.5 text-xs font-medium transition-all sm:text-sm';
      filterContainer.appendChild(activeTagPill);

      activeTagPill.addEventListener('click', () => {
        removeActiveTagPill();
        clearTagQueryParam();
        rows.forEach((row) => {
          row.style.display = '';
        });
      });
    }

    if (activeTagPill) {
      activeTagPill.textContent = `#${tag} ×`;
      activeTagPill.dataset.tag = tag;
    }

    // Filter rows based on tag matching
    rows.forEach((row) => {
      const tags = row.dataset.tags ? row.dataset.tags.split(',') : [];
      row.style.display = tags.includes(tag) ? '' : 'none';
    });

    setTagQueryParam(tag);
  }

  // Register filter function globally for Layout.astro to call
  (window as any).__filterByTag = filterByTag;

  // On page load, auto-filter if tag param exists
  const params = new URLSearchParams(window.location.search);
  const tagParam = params.get('tag');
  if (tagParam) {
    setTimeout(() => {
      filterByTag(tagParam);
    }, 0);
  }
</script>

<style is:global>
  /* Pill styles for the dynamic active tag pill */
  .feed-pill {
    border-color: #e2e8f0;
    color: #64748b;
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
  }
  .feed-pill:hover {
    border-color: #2563eb;
    color: #2563eb;
    background: #eff6ff;
  }
  .feed-pill.active {
    border-color: #2563eb;
    color: #fff;
    background: #2563eb;
  }
  .dark .feed-pill {
    border-color: #334155;
    color: #94a3b8;
  }
  .dark .feed-pill:hover {
    border-color: #60a5fa;
    color: #60a5fa;
    background: #1e3a5f;
  }
  .dark .feed-pill.active {
    border-color: #60a5fa;
    color: #fff;
    background: #2563eb;
  }
</style>

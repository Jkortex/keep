---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

/** 分类 slug → 图标 SVG 的映射 */
const CATEGORY_ICONS: Record<string, string> = {
  principles: 'cpu',
  css: 'file-code',
  mysql: 'database',
  redis: 'layers',
  engineering: 'lightbulb',
};

/** 分类 slug → 描述 */
const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  principles: 'CAP 定理、康威定律、SOLID、BASE 理论……',
  css: 'Flexbox、Grid、动画——效果预览与源码并排展示',
  mysql: '事务隔离级别、索引策略、查询优化……',
  redis: '数据类型、持久化、缓存策略……',
  engineering: '架构决策、工程文化、方法论……',
};

function getIconSvg(name: string): string {
  const icons: Record<string, string> = {
    cpu: `<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>`,
    'file-code': `<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m5 12-3 3 3 3"/><path d="m9 18 3-3-3-3"/></svg>`,
    database: `<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
    layers: `<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    lightbulb: `<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>`,
  };
  return icons[name] ?? icons.cpu!;
}

const articles = await getCollection('knowledge');

// Group by category slug
const categoryMap = new Map<string, CollectionEntry<'knowledge'>[]>();

for (const article of articles) {
  const slug = article.id.split('/')[0];
  if (!categoryMap.has(slug)) {
    categoryMap.set(slug, []);
  }
  categoryMap.get(slug)!.push(article);
}

interface CategoryInfo {
  slug: string;
  title: string;
  description: string;
  count: number;
}

const categories: CategoryInfo[] = Array.from(categoryMap.entries())
  .map(([slug, items]) => ({
    slug,
    title: items[0].data.category,
    description: CATEGORY_DESCRIPTIONS[slug] ?? `${items[0].data.category} 相关知识`,
    count: items.length,
  }))
  .sort((a, b) => a.title.localeCompare(b.title, 'zh'));
---

<div class="grid gap-5 sm:grid-cols-2">
  {categories.map((cat) => (
    <a
      href={'/knowledge/' + cat.slug}
      class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md no-underline dark:border-slate-700 dark:bg-slate-800/50 dark:hover:bg-slate-800"
    >
      <div
        class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-slate-700 dark:text-blue-400"
        set:html={getIconSvg(CATEGORY_ICONS[cat.slug] ?? 'cpu')}
      />
      <h2 class="text-base font-semibold text-slate-900 transition-colors group-hover:text-blue-600 dark:text-slate-100 dark:group-hover:text-blue-400">
        {cat.title}
      </h2>
      <p class="mt-1.5 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
        {cat.description}
      </p>
      <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-blue-600 dark:text-blue-400">
        {cat.count} 篇
        <svg class="h-3 w-3" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </span>
    </a>
  ))}
</div>

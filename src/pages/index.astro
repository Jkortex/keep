---
import Layout from '../layouts/Layout.astro';
import CategoryCard from '../components/CategoryCard.astro';
---

<Layout>
  <section class="not-prose">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
        Keep
      </h1>
      <p class="mx-auto mt-3 max-w-lg text-lg text-slate-500 dark:text-slate-400">
        知识记录平台 — 原则、定理、CSS 示例与技术思考
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <CategoryCard
        href="/knowledge/principles"
        title="软件工程原则"
        description="CAP 定理、康威定律、SOLID、BASE 理论……"
        count={2}
      >
        <svg slot="icon" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
          <path d="M9 22v-4h6v4" />
          <path d="M8 6h.01" /><path d="M16 6h.01" /><path d="M12 6h.01" />
          <path d="M12 10h.01" /><path d="M12 14h.01" />
          <path d="M16 10h.01" /><path d="M16 14h.01" />
          <path d="M8 10h.01" /><path d="M8 14h.01" />
        </svg>
      </CategoryCard>

      <CategoryCard
        href="/knowledge/css/flexbox"
        title="CSS 示例"
        description="Flexbox、Grid、动画——效果预览与源码并排展示"
        count={1}
      >
        <svg slot="icon" class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4" />
          <path d="M14 2v4a2 2 0 0 0 2 2h4" />
          <path d="m5 12-3 3 3 3" />
          <path d="m9 18 3-3-3-3" />
        </svg>
      </CategoryCard>
    </div>
  </section>
</Layout>

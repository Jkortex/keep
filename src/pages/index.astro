---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="not-prose">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-stone-900">Keep</h1>
      <p class="mt-2 text-lg text-stone-500">
        知识记录平台 — 原则、定理、CSS 示例与技术思考
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <a href="/knowledge/principles" class="group block rounded-xl border border-stone-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md no-underline">
        <div class="mb-3 text-3xl">📐</div>
        <h2 class="text-lg font-semibold text-stone-900 group-hover:text-brand-600 transition-colors">软件工程原则</h2>
        <p class="mt-1 text-sm text-stone-500">CAP 定理、康威定律、SOLID、BASE 理论……</p>
        <span class="mt-3 inline-block text-xs font-medium text-brand-600">2 篇</span>
      </a>

      <a href="/knowledge/css/flexbox" class="group block rounded-xl border border-stone-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md no-underline">
        <div class="mb-3 text-3xl">🎨</div>
        <h2 class="text-lg font-semibold text-stone-900 group-hover:text-brand-600 transition-colors">CSS 示例</h2>
        <p class="mt-1 text-sm text-stone-500">Flexbox、Grid、动画——效果预览与源码并排展示</p>
        <span class="mt-3 inline-block text-xs font-medium text-brand-600">1 篇</span>
      </a>
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import CategoryListing from '../../components/CategoryListing.astro';
import Icon from '../../components/Icon.astro';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import * as k from '../../lib/knowledge';

export async function getStaticPaths() {
  const PER_PAGE = 20;
  const allArticles = await k.getArticles();

  // Unique category slugs from entry IDs
  const categories = [...new Set(allArticles.map((a) => k.getCategorySlug(a)))];

  const paths: {
    params: { slug: string | undefined };
    props: Record<string, unknown>;
  }[] = [];

  // Category listing pages with pagination: /knowledge/principles, /knowledge/principles/2, etc.
  for (const cat of categories) {
    const catArticles = allArticles.filter((a) => k.getCategorySlug(a) === cat);
    if (catArticles.length === 0) continue;

    const totalPages = Math.ceil(catArticles.length / PER_PAGE);

    for (let page = 1; page <= totalPages; page++) {
      const start = (page - 1) * PER_PAGE;
      const end = start + PER_PAGE;
      const pageArticles = catArticles.slice(start, end);

      paths.push({
        params: { slug: page === 1 ? cat : `${cat}/${page}` },
        props: {
          pageType: 'category',
          category: cat,
          pageArticles,
          currentPage: page,
          totalPages,
        },
      });
    }
  }

  // Article pages: /knowledge/principles/cap-theorem, etc.
  for (const article of allArticles) {
    paths.push({
      params: { slug: article.id },
      props: { pageType: 'article', entry: article },
    });
  }

  return paths;
}

const {
  pageType,
  category,
  entry,
  pageArticles = [],
  currentPage = 1,
  totalPages = 1,
} = Astro.props as any;

let ArticleContent: any;
let title: string;
let headings: any[] = [];

// ── Prev / Next / Related articles ──
let prevArticle: CollectionEntry<'knowledge'> | undefined;
let nextArticle: CollectionEntry<'knowledge'> | undefined;
let relatedArticles: CollectionEntry<'knowledge'>[] = [];
let readingTime = 0;

if (pageType === 'article' && entry) {
  const { Content, headings: entryHeadings } = await render(entry);
  ArticleContent = Content;
  headings = entryHeadings;
  title = entry.data.title;

  // Reading time (~300 chars/min for Chinese)
  const rawText = entry.body ?? '';
  readingTime = Math.max(1, Math.ceil(rawText.length / 300));

  // All articles sorted
  const allArticles = await k.getArticles();
  const idx = allArticles.findIndex((a: CollectionEntry<'knowledge'>) => a.id === entry.id);
  if (idx > 0) prevArticle = allArticles[idx - 1];
  if (idx < allArticles.length - 1) nextArticle = allArticles[idx + 1];

  // Related articles by shared tags
  const tags = entry.data.tags ?? [];
  if (tags.length > 0) {
    relatedArticles = allArticles
      .filter((a: CollectionEntry<'knowledge'>) => a.id !== entry.id)
      .map((a: CollectionEntry<'knowledge'>) => ({
        article: a,
        score: (a.data.tags ?? []).filter((t) => tags.includes(t)).length,
      }))
      .filter((x) => x.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 3)
      .map((x) => x.article);
  }
} else if (pageType === 'category' && category) {
  title = k.getCategoryLabel(category);
} else {
  title = '知识';
}
---

<Layout
  title={title}
  currentTitle={pageType === 'article' ? entry?.data.title : undefined}
  wide
>
  {
    pageType === 'category' && category ? (
      <CategoryListing
        category={category}
        articles={pageArticles}
        currentPage={currentPage}
        totalPages={totalPages}
      />
    ) : (
      ArticleContent &&
      entry && (
        <div class="lg:grid lg:grid-cols-[1fr_auto] lg:gap-10 items-start">
          <div class="min-w-0">
            <header class="mb-8 border-b border-slate-100 pb-6 dark:border-slate-800 not-prose">
              <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
                {entry.data.title}
              </h1>
              <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-slate-400 dark:text-slate-500">
                <span class="flex items-center gap-1.5">
                  <Icon name="calendar" size={14} />
                  发布于{' '}
                  <span data-pagefind-meta="date">{entry.data.created ? entry.data.created.toISOString().slice(0, 10) : '未知'}</span>
                  {!entry.data.created && '未知'}
                </span>
                {entry.data.updated &&
                  entry.data.created &&
                  entry.data.updated.toISOString().slice(0, 10) !==
                    entry.data.created.toISOString().slice(0, 10) && (
                    <span class="flex items-center gap-1.5">
                      <Icon name="clock" size={14} />
                      更新于 {entry.data.updated.toISOString().slice(0, 10)}
                    </span>
                  )}
                <span class="flex items-center gap-1.5">
                  <Icon name="folder" size={14} />
                  <span data-pagefind-meta="category">{entry.data.category}</span>
                </span>
                {readingTime > 0 && (
                  <span class="flex items-center gap-1.5">
                    <Icon name="clock" size={14} />
                    {readingTime} 分钟阅读
                  </span>
                )}
              </div>
            </header>
            <div class="prose max-w-none">
              <ArticleContent />
            </div>

            <!-- Related articles -->
            {relatedArticles.length > 0 && (
              <div class="not-prose mt-12">
                <h2 class="text-[13px] font-semibold uppercase tracking-wider text-[#9CA3AF] dark:text-[#6B7280]">相关文章</h2>
                <div class="mt-3 space-y-1">
                  {relatedArticles.map((r) => (
                    <a
                      href={`/knowledge/${r.id}`}
                      class="group flex items-center gap-3 rounded-lg px-3 py-2 -mx-3 text-[14px] font-medium text-[#1A1A1A] no-underline transition-colors duration-200 hover:bg-[#F0F9F6] dark:text-[#E5E7EB] dark:hover:bg-[#1F2937]"
                    >
                      <Icon name="file" size={14} class="shrink-0 text-[#D1D5DB] group-hover:text-[#059669] dark:text-[#4B5563] dark:group-hover:text-[#34D399]" />
                      <span class="truncate">{r.data.title}</span>
                      <span class="ml-auto shrink-0 text-[12px] text-[#9CA3AF] dark:text-[#6B7280]">{r.data.category}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}

            <!-- Prev / Next navigation -->
            {(prevArticle || nextArticle) && (
              <nav class="not-prose mt-8 flex items-stretch gap-4 border-t border-slate-200 pt-6 dark:border-slate-800">
                {prevArticle ? (
                  <a
                    href={`/knowledge/${prevArticle.id}`}
                    class="group flex flex-1 items-center gap-3 rounded-xl border border-[#E5E7EB] p-4 no-underline transition-colors duration-200 hover:border-[#059669] hover:bg-[#F9FAF7] dark:border-[#374151] dark:hover:border-[#34D399] dark:hover:bg-[#1A221E]"
                  >
                    <svg class="h-4 w-4 shrink-0 text-[#9CA3AF] transition-colors group-hover:text-[#059669] dark:group-hover:text-[#34D399]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    <div class="min-w-0 flex-1 text-right">
                      <div class="text-[11px] font-medium uppercase tracking-wider text-[#9CA3AF] dark:text-[#6B7280]">上一篇</div>
                      <div class="mt-0.5 truncate text-[14px] font-medium text-[#1A1A1A] group-hover:text-[#059669] dark:text-[#F3F4F6] dark:group-hover:text-[#34D399]">{prevArticle.data.title}</div>
                    </div>
                  </a>
                ) : (
                  <div class="flex-1"></div>
                )}
                {nextArticle ? (
                  <a
                    href={`/knowledge/${nextArticle.id}`}
                    class="group flex flex-1 items-center gap-3 rounded-xl border border-[#E5E7EB] p-4 no-underline transition-colors duration-200 hover:border-[#059669] hover:bg-[#F9FAF7] dark:border-[#374151] dark:hover:border-[#34D399] dark:hover:bg-[#1A221E]"
                  >
                    <div class="min-w-0 flex-1">
                      <div class="text-[11px] font-medium uppercase tracking-wider text-[#9CA3AF] dark:text-[#6B7280]">下一篇</div>
                      <div class="mt-0.5 truncate text-[14px] font-medium text-[#1A1A1A] group-hover:text-[#059669] dark:text-[#F3F4F6] dark:group-hover:text-[#34D399]">{nextArticle.data.title}</div>
                    </div>
                    <svg class="h-4 w-4 shrink-0 text-[#9CA3AF] transition-colors group-hover:text-[#059669] dark:group-hover:text-[#34D399]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                ) : (
                  <div class="flex-1"></div>
                )}
              </nav>
            )}
          </div>

          {headings && headings.length > 0 && (
            <!-- Desktop TOC sidebar -->
            <aside class="hidden lg:block w-56 sticky top-24 max-h-[calc(100dvh-8rem)] overflow-y-auto pl-4 border-l border-slate-200 dark:border-slate-800 not-prose">
              <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4">
                目录
              </h2>
              <nav class="space-y-2">
                {headings
                  .filter((h) => h.depth >= 2 && h.depth <= 3)
                  .map((h) => (
                    <a
                      href={`#${h.slug}`}
                      class:list={[
                        'block text-xs text-slate-500 hover:text-[#059669] dark:text-slate-400 dark:hover:text-[#34D399] transition-colors leading-relaxed no-underline',
                        h.depth === 3 ? 'pl-3' : 'font-medium',
                      ]}
                      data-toc-link-desktop={h.slug}
                    >
                      {h.text}
                    </a>
                  ))}
              </nav>
            </aside>

            <!-- Mobile TOC trigger button -->
            <button
              id="toc-mobile-trigger"
              class="lg:hidden fixed right-4 bottom-20 z-40 flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-[#E5E7EB] bg-white text-[#6B7280] shadow-lg transition-colors duration-200 hover:border-[#059669] hover:text-[#059669] dark:border-[#374151] dark:bg-[#1F2937] dark:text-[#9CA3AF] dark:hover:border-[#34D399] dark:hover:text-[#34D399]"
              style="bottom: calc(5rem + env(safe-area-inset-bottom, 0px))"
              aria-label="打开目录"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>

            <!-- Mobile TOC drawer -->
            <div
              id="toc-mobile-overlay"
              class="lg:hidden fixed inset-0 z-[150] hidden items-end justify-center bg-black/30 backdrop-blur-sm"
            >
              <div class="w-full max-w-lg rounded-t-2xl border border-[#E5E7EB] bg-[#FAFAF8] p-5 shadow-2xl dark:border-[#374151] dark:bg-[#1F2937]">
                <div class="mb-4 flex items-center justify-between">
                  <h2 class="text-[16px] font-semibold text-[#1A1A1A] dark:text-[#F3F4F6]">目录</h2>
                  <button
                    id="toc-mobile-close"
                    class="inline-flex min-h-[44px] min-w-[44px] sm:h-7 sm:w-7 items-center justify-center rounded-lg text-[#9CA3AF] transition-colors duration-200 hover:bg-[#F3F4F6] hover:text-[#1A1A1A] dark:hover:bg-[#374151] dark:hover:text-[#F3F4F6]"
                    aria-label="关闭目录"
                  >
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                    </svg>
                  </button>
                </div>
                <nav class="space-y-2 max-h-[50vh] overflow-y-auto">
                  {headings
                    .filter((h) => h.depth >= 2 && h.depth <= 3)
                    .map((h) => (
                      <a
                        href={`#${h.slug}`}
                        class:list={[
                          'block text-sm text-slate-600 hover:text-[#059669] dark:text-slate-300 dark:hover:text-[#34D399] transition-colors leading-relaxed no-underline rounded-lg px-3 py-1.5 hover:bg-[#F3F4F6] dark:hover:bg-[#374151]',
                          h.depth === 3 ? 'pl-6' : 'font-medium',
                        ]}
                        data-toc-link-mobile={h.slug}
                      >
                        {h.text}
                      </a>
                    ))}
                </nav>
              </div>
            </div>
          )}
        </div>
      )
    )
  }
</Layout>

<script>
  // ── TOC active state tracker (desktop + mobile) ──
  const desktopLinks = document.querySelectorAll('[data-toc-link-desktop]');
  const mobileLinks = document.querySelectorAll('[data-toc-link-mobile]');
  const headings = Array.from(document.querySelectorAll('article h2, article h3')).filter(
    (h) => h.id,
  );

  function updateTocActive(activeId: string) {
    [...desktopLinks, ...mobileLinks].forEach((link) => {
      const el = link as HTMLElement;
      const isActive = (el.dataset.tocLinkDesktop || el.dataset.tocLinkMobile) === activeId;
      el.classList.toggle('text-[#059669]', isActive);
      el.classList.toggle('dark:text-[#34D399]', isActive);
      el.classList.toggle('font-semibold', isActive);
      el.classList.toggle('text-slate-500', !isActive);
      el.classList.toggle('dark:text-slate-400', !isActive);
    });
  }

  if ((desktopLinks.length > 0 || mobileLinks.length > 0) && headings.length > 0) {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60% 0px',
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      let activeId = '';
      for (const entry of entries) {
        if (entry.isIntersecting) {
          activeId = entry.target.id;
          break;
        }
      }

      if (!activeId) {
        const top = window.scrollY;
        for (let i = headings.length - 1; i >= 0; i--) {
          const h = headings[i] as HTMLElement;
          if (h.offsetTop <= top + 200) {
            activeId = h.id;
            break;
          }
        }
      }

      if (activeId) {
        updateTocActive(activeId);
      }
    }, observerOptions);

    headings.forEach((h) => observer.observe(h));
  }

  // ── Mobile TOC drawer ──
  const tocTrigger = document.getElementById('toc-mobile-trigger');
  const tocOverlay = document.getElementById('toc-mobile-overlay');
  const tocClose = document.getElementById('toc-mobile-close');

  function openTocDrawer() {
    if (!tocOverlay) return;
    tocOverlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeTocDrawer() {
    if (!tocOverlay) return;
    tocOverlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  tocTrigger?.addEventListener('click', openTocDrawer);
  tocClose?.addEventListener('click', closeTocDrawer);
  tocOverlay?.addEventListener('click', (e) => {
    if (e.target === tocOverlay) closeTocDrawer();
  });

  // Close drawer when a TOC link is clicked
  tocOverlay?.querySelectorAll('[data-toc-link-mobile]').forEach((link) => {
    link.addEventListener('click', () => {
      closeTocDrawer();
    });
  });

  // ── Copy heading link on hover ──
  const article = document.querySelector('article.prose');
  if (article) {
    article.querySelectorAll('h2, h3').forEach((h) => {
      if (!h.id) return;
      const anchor = document.createElement('a');
      anchor.href = `#${h.id}`;
      anchor.className =
        'heading-anchor ml-1 no-underline opacity-0 transition-opacity duration-150 text-[#9CA3AF] hover:text-[#059669] dark:hover:text-[#34D399]';
      anchor.setAttribute('aria-label', '复制标题链接');
      anchor.innerHTML = '<svg class="inline-block h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
      h.classList.add('group');
      h.appendChild(anchor);

      h.addEventListener('mouseenter', () => { anchor.style.opacity = '1'; });
      h.addEventListener('mouseleave', () => { anchor.style.opacity = '0'; });

      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const url = window.location.href.split('#')[0] + '#' + h.id;
        navigator.clipboard.writeText(url).catch(() => {});
        anchor.style.opacity = '1';
        anchor.innerHTML = '<svg class="inline-block h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => {
          anchor.innerHTML = '<svg class="inline-block h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
        }, 1500);
      });
    });
  }
</script>

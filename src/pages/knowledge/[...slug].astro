---
import Layout from '../../layouts/Layout.astro';
import CategoryListing from '../../components/CategoryListing.astro';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import * as k from '../../lib/knowledge';

export async function getStaticPaths() {
  const PER_PAGE = 20;
  const allArticles = await k.getArticles();

  // Unique category slugs from entry IDs
  const categories = [...new Set(allArticles.map((a) => k.getCategorySlug(a)))];

  const paths: {
    params: { slug: string | undefined };
    props: Record<string, unknown>;
  }[] = [];

  // Category listing pages with pagination: /knowledge/principles, /knowledge/principles/2, etc.
  for (const cat of categories) {
    const catArticles = allArticles.filter((a) => k.getCategorySlug(a) === cat);
    if (catArticles.length === 0) continue;

    const totalPages = Math.ceil(catArticles.length / PER_PAGE);

    for (let page = 1; page <= totalPages; page++) {
      const start = (page - 1) * PER_PAGE;
      const end = start + PER_PAGE;
      const pageArticles = catArticles.slice(start, end);

      paths.push({
        params: { slug: page === 1 ? cat : `${cat}/${page}` },
        props: {
          pageType: 'category',
          category: cat,
          pageArticles,
          currentPage: page,
          totalPages,
        },
      });
    }
  }

  // Article pages: /knowledge/principles/cap-theorem, etc.
  for (const article of allArticles) {
    paths.push({
      params: { slug: article.id },
      props: { pageType: 'article', entry: article },
    });
  }

  return paths;
}

const {
  pageType,
  category,
  entry,
  pageArticles = [],
  currentPage = 1,
  totalPages = 1,
} = Astro.props as any;

let ArticleContent: any;
let title: string;
let headings: any[] = [];

if (pageType === 'article' && entry) {
  const { Content, headings: entryHeadings } = await render(entry);
  ArticleContent = Content;
  headings = entryHeadings;
  title = entry.data.title;
} else if (pageType === 'category' && category) {
  title = k.getCategoryLabel(category);
} else {
  title = '知识';
}
---

<Layout
  title={title}
  currentTitle={pageType === 'article' ? entry?.data.title : undefined}
  wide
>
  {
    pageType === 'category' && category ? (
      <CategoryListing
        category={category}
        articles={pageArticles}
        currentPage={currentPage}
        totalPages={totalPages}
      />
    ) : (
      ArticleContent &&
      entry && (
        <div class="lg:grid lg:grid-cols-[1fr_auto] lg:gap-10 items-start">
          <div class="min-w-0">
            <header class="mb-8 border-b border-slate-100 pb-6 dark:border-slate-800 not-prose">
              <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
                {entry.data.title}
              </h1>
              <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-slate-400 dark:text-slate-500">
                <span class="flex items-center gap-1.5">
                  <svg
                    class="h-3.5 w-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                      <line x1="16" y1="2" x2="16" y2="6" />
                      <line x1="8" y1="2" x2="8" y2="6" />
                      <line x1="3" y1="10" x2="21" y2="10" />
                    </>
                  </svg>
                  发布于{' '}
                  {entry.data.created ? entry.data.created.toISOString().slice(0, 10) : '未知'}
                </span>
                {entry.data.updated &&
                  entry.data.created &&
                  entry.data.updated.toISOString().slice(0, 10) !==
                    entry.data.created.toISOString().slice(0, 10) && (
                    <span class="flex items-center gap-1.5">
                      <svg
                        class="h-3.5 w-3.5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67" />
                      </svg>
                      更新于 {entry.data.updated.toISOString().slice(0, 10)}
                    </span>
                  )}
                <span class="flex items-center gap-1.5">
                  <svg
                    class="h-3.5 w-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2-2.5z" />
                      <path d="M6 6h15M6 10h10" />
                    </>
                  </svg>
                  {entry.data.category}
                </span>
              </div>
            </header>
            <div class="prose max-w-none">
              <ArticleContent />
            </div>
          </div>

          {headings && headings.length > 0 && (
            <aside class="hidden lg:block w-56 sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto pl-4 border-l border-slate-200 dark:border-slate-800 not-prose">
              <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4">
                目录
              </h2>
              <nav class="space-y-2">
                {headings
                  .filter((h) => h.depth >= 2 && h.depth <= 3)
                  .map((h) => (
                    <a
                      href={`#${h.slug}`}
                      class:list={[
                        'block text-xs text-slate-500 hover:text-[#059669] dark:text-slate-400 dark:hover:text-[#34D399] transition-colors leading-relaxed no-underline',
                        h.depth === 3 ? 'pl-3' : 'font-medium',
                      ]}
                      data-toc-link={h.slug}
                    >
                      {h.text}
                    </a>
                  ))}
              </nav>
            </aside>
          )}
        </div>
      )
    )
  }
</Layout>

<script>
  // ── TOC active state tracker ──
  const links = document.querySelectorAll('[data-toc-link]');
  const headings = Array.from(document.querySelectorAll('article h2, article h3')).filter(
    (h) => h.id,
  );

  if (links.length > 0 && headings.length > 0) {
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -60% 0px',
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      // Find the first heading that is intersecting in the upper half of the viewport
      let activeId = '';
      for (const entry of entries) {
        if (entry.isIntersecting) {
          activeId = entry.target.id;
          break;
        }
      }

      // Fallback: if no headings are currently intersecting, find the closest one above the viewport
      if (!activeId) {
        const top = window.scrollY;
        for (let i = headings.length - 1; i >= 0; i--) {
          const h = headings[i] as HTMLElement;
          if (h.offsetTop <= top + 200) {
            activeId = h.id;
            break;
          }
        }
      }

      if (activeId) {
        links.forEach((link) => {
          const linkHtml = link as HTMLElement;
          const isActive = linkHtml.dataset.tocLink === activeId;
          linkHtml.classList.toggle('text-[#059669]', isActive);
          linkHtml.classList.toggle('dark:text-[#34D399]', isActive);
          linkHtml.classList.toggle('font-semibold', isActive);
          linkHtml.classList.toggle('text-slate-500', !isActive);
          linkHtml.classList.toggle('dark:text-slate-400', !isActive);
        });
      }
    }, observerOptions);

    headings.forEach((h) => observer.observe(h));
  }
</script>

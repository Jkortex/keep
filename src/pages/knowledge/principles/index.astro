---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="软件工程原则">
  <section class="not-prose">
    <div class="mb-6 flex items-center gap-3">
      <div
        class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-slate-700 dark:text-blue-400"
      >
        <svg
          class="h-5 w-5"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
          <path d="M9 22v-4h6v4"></path>
          <path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path>
          <path d="M12 10h.01"></path><path d="M12 14h.01"></path>
          <path d="M16 10h.01"></path><path d="M16 14h.01"></path>
          <path d="M8 10h.01"></path><path d="M8 14h.01"></path>
        </svg>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
        软件工程原则
      </h1>
    </div>

    <div class="space-y-0.5">
      <a
        href="/knowledge/principles/cap-theorem"
        class="flex items-center gap-2 rounded-lg px-3 py-2.5 -mx-3 text-slate-600 no-underline transition-colors hover:bg-slate-50 hover:text-blue-600 dark:text-slate-400 dark:hover:bg-slate-800/50 dark:hover:text-blue-400"
      >
        <svg
          class="h-4 w-4 shrink-0 text-slate-400 dark:text-slate-500"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
        <div>
          <div class="text-sm font-medium">CAP 定理</div>
          <div class="mt-0.5 text-xs text-slate-400 dark:text-slate-500">
            Consistency、Availability、Partition Tolerance
          </div>
        </div>
      </a>
      <a
        href="/knowledge/principles/conways-law"
        class="flex items-center gap-2 rounded-lg px-3 py-2.5 -mx-3 text-slate-600 no-underline transition-colors hover:bg-slate-50 hover:text-blue-600 dark:text-slate-400 dark:hover:bg-slate-800/50 dark:hover:text-blue-400"
      >
        <svg
          class="h-4 w-4 shrink-0 text-slate-400 dark:text-slate-500"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
        <div>
          <div class="text-sm font-medium">康威定律</div>
          <div class="mt-0.5 text-xs text-slate-400 dark:text-slate-500">组织架构决定系统架构</div>
        </div>
      </a>
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="所有知识">
  <section class="not-prose">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">所有知识</h1>

    <div class="mt-10">
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
            <path d="M9 22v-4h6v4" />
            <path d="M8 6h.01" /><path d="M16 6h.01" /><path d="M12 6h.01" />
            <path d="M12 10h.01" /><path d="M12 14h.01" />
            <path d="M16 10h.01" /><path d="M16 14h.01" />
            <path d="M8 10h.01" /><path d="M8 14h.01" />
          </svg>
          <h2 class="text-lg font-semibold text-slate-800">软件工程原则</h2>
        </div>
        <div class="space-y-0.5">
          <a href="/knowledge/principles/cap-theorem" class="flex items-center gap-2 py-2 px-3 -mx-3 rounded-lg text-slate-600 hover:text-blue-600 hover:bg-slate-50 transition-colors no-underline text-sm">
            <svg class="h-4 w-4 shrink-0 text-slate-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
            <span class="font-medium">CAP 定理</span>
            <span class="text-slate-400">&mdash; Consistency、Availability、Partition Tolerance</span>
          </a>
          <a href="/knowledge/principles/conways-law" class="flex items-center gap-2 py-2 px-3 -mx-3 rounded-lg text-slate-600 hover:text-blue-600 hover:bg-slate-50 transition-colors no-underline text-sm">
            <svg class="h-4 w-4 shrink-0 text-slate-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
            <span class="font-medium">康威定律</span>
            <span class="text-slate-400">&mdash; 组织架构决定系统架构</span>
          </a>
        </div>
      </div>

      <div>
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 22h14a2 2 0 0 0 2-2V7l-5-5H6a2 2 0 0 0-2 2v4" />
            <path d="M14 2v4a2 2 0 0 0 2 2h4" />
            <path d="m5 12-3 3 3 3" />
            <path d="m9 18 3-3-3-3" />
          </svg>
          <h2 class="text-lg font-semibold text-slate-800">CSS 示例</h2>
        </div>
        <div class="space-y-0.5">
          <a href="/knowledge/css/flexbox" class="flex items-center gap-2 py-2 px-3 -mx-3 rounded-lg text-slate-600 hover:text-blue-600 hover:bg-slate-50 transition-colors no-underline text-sm">
            <svg class="h-4 w-4 shrink-0 text-slate-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
            <span class="font-medium">Flexbox 居中</span>
            <span class="text-slate-400">&mdash; 含效果预览与源码展示</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

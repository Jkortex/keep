---
import Layout from '../layouts/Layout.astro';
---

<Layout title="搜索">
  <section class="not-prose" data-pagefind-ignore>
    <h1 class="text-[28px] font-semibold tracking-tight text-[#1A1A1A] dark:text-[#F3F4F6]">搜索</h1>
    <div class="mt-6">
      <div class="relative">
        <svg
          class="pointer-events-none absolute left-3 top-1/2 h-[18px] w-[18px] -translate-y-1/2 text-[#9CA3AF]"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="搜索所有知识…"
          class="w-full rounded-xl border border-[#E5E7EB] bg-white py-3 pl-10 pr-4 text-[15px] text-[#1A1A1A] placeholder:text-[#9CA3AF] focus:border-[#059669] focus:outline-none focus:ring-2 focus:ring-[#ECFDF5] dark:border-[#374151] dark:bg-[#1F2937] dark:text-[#F3F4F6] dark:placeholder:text-[#6B7280] dark:focus:border-[#059669] dark:focus:ring-[rgba(5,150,105,0.2)]"
        />
      </div>
      <div id="search-count" class="mt-4 text-[13px] text-[#9CA3AF] dark:text-[#6B7280]"></div>
      <div id="search-results" class="mt-2"></div>
    </div>
  </section>

  <script>
    import { setupSearch } from '../scripts/search';
    setupSearch();
  </script>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="搜索">
  <section class="not-prose" data-pagefind-ignore>
    <h1 class="text-[28px] font-semibold tracking-tight text-foreground">搜索</h1>
    <div class="mt-6">
      <div class="relative">
        <Icon name="search" size={18} class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-dim" />
        <input
          id="search-input"
          type="search"
          placeholder="搜索所有知识…"
          class="w-full rounded-xl border border-border bg-white py-3 pl-10 pr-4 text-[15px] text-foreground placeholder:text-dim focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent-light dark:bg-muted dark:focus:ring-[rgba(5,150,105,0.2)]"
        />
      </div>
      <div id="search-count" class="mt-4 text-[13px] text-dim"></div>
      <div id="search-results" class="mt-2"></div>
    </div>
  </section>

  <script>
    import { setupSearch } from '../scripts/search';
    setupSearch();
  </script>
</Layout>

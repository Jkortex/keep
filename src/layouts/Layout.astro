---
import '../styles/app.css';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import HotkeyHelp from '../components/HotkeyHelp.astro';
import CommandPalette from '../components/CommandPalette.astro';
import Icon from '../components/Icon.astro';
import type { PageMeta } from '../types';
import { getCollection } from 'astro:content';
import { getCategorySlug } from '../lib/knowledge';

export interface Props extends Partial<PageMeta> {
  wide?: boolean;
  currentTitle?: string;
}

const { title = 'Keep', wide = false, currentTitle } = Astro.props as Props;
const siteTitle: string = title === 'Keep' ? 'Keep' : `${title} — Keep`;

const allArticles = await getCollection('knowledge');
const palettePages = allArticles.map((a) => ({
  title: a.data.title,
  url: `/knowledge/${a.id}`,
  category: a.data.category,
  categorySlug: getCategorySlug(a),
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>

    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col transition-colors duration-200">
    <!-- Nav -->
    <header
      data-pagefind-ignore
      class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-md dark:bg-background/80"
    >
      <nav class:list={['mx-auto flex items-center justify-between px-5 py-3.5', wide ? 'max-w-5xl' : 'max-w-3xl']}>
        <a href="/" class="flex items-center gap-2 no-underline group">
          <span class="text-[17px] font-semibold tracking-tight text-foreground group-hover:text-accent transition-colors duration-200"
            >Keep</span
          >
        </a>
        <div class="flex items-center gap-5">
          <button id="palette-toggle" class="cursor-pointer text-[15px] font-medium text-subtle no-underline transition-colors duration-200 hover:text-accent" aria-label="命令面板" title="命令面板 (Ctrl+P)">
            <Icon name="command" size={18} />
          </button>
          <a
            href="/search"
            class="text-[15px] font-medium text-subtle no-underline transition-colors duration-200 hover:text-accent"
            aria-label="搜索"
          >
            <Icon name="search" size={18} />
          </a>
          <button id="theme-toggle" class="cursor-pointer text-[15px] font-medium text-subtle transition-colors duration-200 hover:text-accent" aria-label="切换主题" type="button">
            <span id="sun-icon" class="hidden"><Icon name="sun" size={18} /></span>
            <span id="moon-icon"><Icon name="moon" size={18} /></span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Page data for command palette -->
    <script is:inline id="palette-pages-data" type="application/json" set:html={JSON.stringify(palettePages)}></script>

    <!-- Main -->
    <main
      class:list={['mx-auto w-full flex-1 px-5 py-10 md:py-16', wide ? 'max-w-5xl' : 'max-w-3xl']}
    >
      <Breadcrumbs path={Astro.url} currentTitle={currentTitle} />
      <article class:list={['prose', wide && 'max-w-none']} data-pagefind-body>
        <slot />
      </article>
    </main>

    <!-- Footer -->
    <footer
      data-pagefind-ignore
      class="border-t border-border py-8 text-center text-[13px] text-dim"
    >
      <span>Keep — 个人知识库</span>
      <span class="mx-2">·</span>
      <a href="/rss.xml" class="text-dim no-underline transition-colors duration-200 hover:text-accent">RSS</a>
    </footer>

    <HotkeyHelp
      shortcuts={[
        { keys: 'Ctrl+P', desc: '命令面板' },
        { keys: 'g h', desc: '回到首页' },
        { keys: '/', desc: '搜索' },
        { keys: 't', desc: '切换主题' },
        { keys: '?', desc: '显示快捷键帮助' },
        { keys: 'Esc', desc: '关闭面板 / 取消输入' },
      ]}
    />

    <CommandPalette />

    <!-- Back to top button -->
    <button
      id="back-to-top"
      class="fixed right-4 bottom-4 z-40 hidden min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-border bg-white text-subtle shadow-lg transition-all duration-200 hover:border-accent hover:text-accent dark:bg-muted"
      style="bottom: calc(1rem + env(safe-area-inset-bottom, 0px))"
      aria-label="回到顶部"
      title="回到顶部"
    >
      <Icon name="chevron-up" size={16} />
    </button>

    <script>
      import { setupLayout } from '../scripts/layout';
      import '../scripts/hotkeys-init.ts';
      setupLayout();
    </script>
  </body>
</html>

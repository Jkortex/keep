---
import '../styles/app.css';

export interface Props {
  title?: string;
}

const { title = 'Keep' } = Astro.props as Props;
const siteTitle = title === 'Keep' ? 'Keep' : `${title} — Keep`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-stone-200 bg-surface/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-stone-900 no-underline">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-500 text-sm text-white font-bold">K</span>
          <span>Keep</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/knowledge" class="text-stone-500 hover:text-brand-600 transition-colors no-underline font-medium">
            所有知识
          </a>
        </div>
      </nav>
    </header>

    <!-- Main -->
    <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-10 md:py-14">
      <article class="prose">
        <slot />
      </article>
    </main>

    <!-- Footer -->
    <footer class="border-t border-stone-200 py-6 text-center text-xs text-stone-400">
      Knowledge Keep
    </footer>
  </body>
</html>

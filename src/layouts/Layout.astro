---
import '../styles/app.css';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import HotkeyHelp from '../components/HotkeyHelp.astro';
import CommandPalette from '../components/CommandPalette.astro';
import type { PageMeta } from '../types';
import { getCollection } from 'astro:content';
import { getCategorySlug } from '../lib/knowledge';

export interface Props extends Partial<PageMeta> {
  wide?: boolean;
  currentTitle?: string;
}

const { title = 'Keep', wide = false, currentTitle } = Astro.props as Props;
const siteTitle: string = title === 'Keep' ? 'Keep' : `${title} — Keep`;

const allArticles = await getCollection('knowledge');
const palettePages = allArticles.map((a) => ({
  title: a.data.title,
  url: `/knowledge/${a.id}`,
  category: a.data.category,
  categorySlug: getCategorySlug(a),
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>

    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col transition-colors duration-200">
    <!-- Nav -->
    <header
      data-pagefind-ignore
      class="sticky top-0 z-50 border-b border-[#E5E7EB] bg-[#FAFAF8]/80 backdrop-blur-md dark:border-[#374151] dark:bg-[#111827]/80"
    >
      <nav class:list={['mx-auto flex items-center justify-between px-5 py-3.5', wide ? 'max-w-5xl' : 'max-w-3xl']}>
        <a href="/" class="flex items-center gap-2 no-underline group">
          <span class="text-[17px] font-semibold tracking-tight text-[#1A1A1A] dark:text-[#F3F4F6] group-hover:text-[#059669] transition-colors duration-200"
            >Keep</span
          >
        </a>
        <div class="flex items-center gap-5">
          <button id="palette-toggle" class="cursor-pointer text-[15px] font-medium text-[#6B7280] no-underline transition-colors duration-200 hover:text-[#059669] dark:text-[#9CA3AF] dark:hover:text-[#34D399]" aria-label="命令面板" title="命令面板 (Ctrl+P)">
            <svg class="h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" />
            </svg>
          </button>
          <a
            href="/search"
            class="text-[15px] font-medium text-[#6B7280] no-underline transition-colors duration-200 hover:text-[#059669] dark:text-[#9CA3AF] dark:hover:text-[#34D399]"
            aria-label="搜索"
          >
            <svg class="h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </a>
          <button id="theme-toggle" class="cursor-pointer text-[15px] font-medium text-[#6B7280] transition-colors duration-200 hover:text-[#059669] dark:text-[#9CA3AF] dark:hover:text-[#34D399]" aria-label="切换主题" type="button">
            <svg id="sun-icon" class="hidden h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path>
              <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
              <path d="M2 12h2"></path><path d="M20 12h2"></path>
              <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
            </svg>
            <svg id="moon-icon" class="h-[18px] w-[18px]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <!-- Page data for command palette -->
    <script id="palette-pages-data" type="application/json" set:html={JSON.stringify(palettePages)}></script>

    <!-- Main -->
    <main
      class:list={['mx-auto w-full flex-1 px-5 py-10 md:py-16', wide ? 'max-w-5xl' : 'max-w-3xl']}
    >
      <Breadcrumbs path={Astro.url} currentTitle={currentTitle} />
      <article class:list={['prose', wide && 'max-w-none']} data-pagefind-body>
        <slot />
      </article>
    </main>

    <!-- Footer -->
    <footer
      data-pagefind-ignore
      class="border-t border-[#E5E7EB] py-8 text-center text-[13px] text-[#9CA3AF] dark:border-[#374151] dark:text-[#6B7280]"
    >
      <span>Keep — 个人知识库</span>
    </footer>

    <HotkeyHelp
      shortcuts={[
        { keys: 'Ctrl+P', desc: '命令面板' },
        { keys: 'g h', desc: '回到首页' },
        { keys: '/', desc: '搜索' },
        { keys: 't', desc: '切换主题' },
        { keys: '?', desc: '显示快捷键帮助' },
        { keys: 'Esc', desc: '关闭面板 / 取消输入' },
      ]}
    />

    <CommandPalette />

    <script is:inline>
      // ── Theme toggle ──
      const toggle = document.getElementById('theme-toggle');
      const sun = document.getElementById('sun-icon');
      const moon = document.getElementById('moon-icon');

      function syncUI(isDark) {
        sun?.classList.toggle('hidden', !isDark);
        moon?.classList.toggle('hidden', isDark);
      }

      syncUI(document.documentElement.classList.contains('dark'));

      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        syncUI(isDark);
      });

      // ── Palette toggle button ──
      document.getElementById('palette-toggle')?.addEventListener('click', function () {
        if (window.__openPalette) window.__openPalette('');
      });
    </script>

    <script src="../scripts/hotkeys-init.ts"></script>
  </body>
</html>
